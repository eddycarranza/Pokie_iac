# ============================================================
# Variables de entorno — Pokie Cat
# Copia este archivo a .env y ajusta los valores:
#   cp .env.example .env
# ============================================================

# ── Base de datos (PostgreSQL) ──────────────────────────────
DB_NAME=pokie
DB_USER=pokie
DB_PASSWORD=cambia_esta_password

# ── Backend ─────────────────────────────────────────────────
# Secreto para firmar los tokens JWT (usa un valor largo y aleatorio)
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio
# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Puerto del host donde se sirve el frontend (cámbialo si 3000 está ocupado)
FRONTEND_PORT=3000

# ── Frontend ────────────────────────────────────────────────
# URL del API que se inyecta al compilar React
REACT_APP_API_URL=http://localhost:4000/api

# ── GHCR (GitHub Container Registry) ────────────────────────
# Owner (usuario/organización) y tag de las imágenes en ghcr.io.
# Se usan en docker-compose para pull/push de las imágenes publicadas por CI.
GHCR_OWNER=rg727876-hub
IMAGE_TAG=latest
